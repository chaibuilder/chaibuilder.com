{
  "name": "chaibuilder-supabase-starter",
  "version": "0.1.4",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npx tailwindcss -c ./tailwind.config.js -i './app/(public)/public.css' -o ./public/chaistyles.css --watch\" \"next dev --port 3000\"",
    "prebuild": "cp .npmrc.vercel .npmrc || true",
    "build": "npx tailwindcss -c ./tailwind.config.js -i './app/(public)/public.css' -o ./public/chaistyles.css --minify && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@chaibuilder/pro": "^0.0.1-beta.11",
    "@next/third-parties": "^16.0.10",
    "@radix-ui/react-icons": "^1.3.2",
    "@supabase/supabase-js": "^2.90.1",
    "ai": "^6.0.116",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lodash": "^4.17.23",
    "next": "^16.1.6",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
